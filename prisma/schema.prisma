generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model attendance {
  id            Int       @id @default(autoincrement())
  member_id     Int?
  check_in_time DateTime? @default(now()) @db.Timestamp(6)
  users         users?    @relation(fields: [member_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model member_workouts {
  id                                                     Int       @id @default(autoincrement())
  member_id                                              Int?
  trainer_id                                             Int?
  workout_id                                             Int?
  assigned_date                                          DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  previous_trainer_id                                    Int?
  users                                                  users?    @relation(fields: [member_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  trainers_member_workouts_previous_trainer_idTotrainers trainers? @relation("member_workouts_previous_trainer_idTotrainers", fields: [previous_trainer_id], references: [id], onUpdate: NoAction)
  trainers_member_workouts_trainer_idTotrainers          trainers? @relation("member_workouts_trainer_idTotrainers", fields: [trainer_id], references: [id], onUpdate: NoAction)
  workouts                                               workouts? @relation(fields: [workout_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model payments {
  id              Int            @id @default(autoincrement())
  subscription_id Int?
  amount          Decimal        @db.Decimal(10, 2)
  payment_date    DateTime?      @default(now()) @db.Timestamp(6)
  status          String?        @default("completed") @db.VarChar(20)
  subscriptions   subscriptions? @relation(fields: [subscription_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model plans {
  id              Int             @id @default(autoincrement())
  name            String          @db.VarChar(100)
  duration_months Int
  price           Decimal         @db.Decimal(10, 2)
  description     String?
  subscriptions   subscriptions[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model subscriptions {
  id         Int        @id @default(autoincrement())
  member_id  Int?
  plan_id    Int?
  start_date DateTime   @db.Date
  end_date   DateTime   @db.Date
  status     String?    @default("active") @db.VarChar(20)
  payments   payments[]
  users      users?     @relation(fields: [member_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  plans      plans?     @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model trainers {
  id                                                            Int               @id @default(autoincrement())
  user_id                                                       Int?
  specialization                                                String?           @db.VarChar(100)
  available_from                                                DateTime?         @db.Time(6)
  available_to                                                  DateTime?         @db.Time(6)
  member_workouts_member_workouts_previous_trainer_idTotrainers member_workouts[] @relation("member_workouts_previous_trainer_idTotrainers")
  member_workouts_member_workouts_trainer_idTotrainers          member_workouts[] @relation("member_workouts_trainer_idTotrainers")
  users                                                         users?            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(100)
  email           String            @unique @db.VarChar(100)
  password        String            @db.VarChar(255)
  role            String?           @default("member") @db.VarChar(20)
  phone           String?           @db.VarChar(20)
  age             Int?
  joining_date    DateTime?         @default(now()) @db.Timestamp(6)
  status          String?           @default("active") @db.VarChar(20)
  attendance      attendance[]
  member_workouts member_workouts[]
  subscriptions   subscriptions[]
  trainers        trainers[]
}

model workouts {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(100)
  description     String?
  member_workouts member_workouts[]
}
